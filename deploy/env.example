# Copy to deploy/env on the VPS and edit values:
#   cp deploy/env.example deploy/env

# Repo root on the server
APP_ROOT=/var/www/maxmac

# Public domains (no trailing slash)
FRONTEND_DOMAIN=maxmacsafaris.com
FRONTEND_DOMAIN_WWW=www.maxmacsafaris.com
WP_DOMAIN=wp.maxmacsafaris.com

# Full URLs used by the app
FRONTEND_ORIGIN=https://maxmacsafaris.com
PUBLIC_WP_URL=https://wp.maxmacsafaris.com

# PHP-FPM socket (check: ls /run/php/)
PHP_FPM_SOCK=unix:/run/php/php8.2-fpm.sock

# Set to 1 to re-import AMS trips into WP on every deploy (slow; usually only for catalog updates)
RUN_WP_IMPORT=0

# Set to 1 to reinstall frontend npm deps on every deploy
NPM_CI=1

# Optional — setup.sh creates these if empty (save the generated password!)
# MYSQL_DB=maxmac_wp
# MYSQL_USER=maxmac
# MYSQL_PASSWORD=
