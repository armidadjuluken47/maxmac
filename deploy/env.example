# =============================================================================
# MaxMac — LIVE server config (maxmacsafaris.com)
# =============================================================================
# On the VPS, copy this file and edit only the password line if needed:
#   cp deploy/env.example deploy/env
#   nano deploy/env          # set MYSQL_PASSWORD
#   sudo ./deploy/setup.sh
# =============================================================================

# Repo root on the server (where you cloned the project)
APP_ROOT=/var/www/maxmac

# --- Domains (no https://, no trailing slash) ---
FRONTEND_DOMAIN=maxmacsafaris.com
FRONTEND_DOMAIN_WWW=www.maxmacsafaris.com
WP_DOMAIN=wp.maxmacsafaris.com

# --- Full URLs (used by Astro build + WordPress CORS) ---
FRONTEND_ORIGIN=https://maxmacsafaris.com
PUBLIC_WP_URL=https://wp.maxmacsafaris.com

# --- MySQL (created by setup.sh; set password before first run) ---
MYSQL_DB=maxmac_wp
MYSQL_USER=maxmac
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD_HERE

# --- PHP-FPM (Ubuntu default; run `ls /run/php/` if setup fails) ---
PHP_FPM_SOCK=unix:/run/php/php8.2-fpm.sock

# --- Import script: USD → KES price conversion ---
AMS_USD_TO_KES=130

# --- Deploy behaviour ---
RUN_WP_IMPORT=0
NPM_CI=1
